# ─── Backend Rifbound TCG — Variables d'environnement ───────────────────────
# Copie ce fichier en ".env" (ne jamais committer .env !)
# Ce fichier .env.example EST commité : il documente les variables nécessaires.

# ─── Serveur ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Base de données — Supabase (PostgreSQL) ─────────────────────────────────
# Dans Supabase → Settings → Database → Connection string
# Utilise le mode "Transaction" (port 6543) si tu es sur le free tier Render
# Utilise le mode "Session" (port 5432) en dev local ou sur Render payant
DATABASE_URL=postgresql://postgres:[MOT_DE_PASSE]@db.[PROJET_REF].supabase.co:6543/postgres?pgbouncer=true

# ─── Supabase — Client JS ────────────────────────────────────────────────────
# Dans Supabase → Settings → API
SUPABASE_URL=https://[PROJET_REF].supabase.co
# Clé publique (anon) — peut être exposée côté frontend
SUPABASE_ANON_KEY=eyJ...
# Clé service_role — JAMAIS côté frontend, serveur uniquement
SUPABASE_SERVICE_KEY=eyJ...

# ─── CORS ────────────────────────────────────────────────────────────────────
# Origines autorisées séparées par des virgules
# Dev : ton serveur de fichiers local (Live Server = 5500, http-server = 8080)
# Prod : ton domaine Vercel
CORS_ORIGIN=http://localhost:5500,http://localhost:8080

# ─── Riot API ────────────────────────────────────────────────────────────────
# Récupérer sur https://developer.riotgames.com/
# La clé de dev expire toutes les 24h — demande une clé de production pour le projet
RIOT_API_KEY=RGAPI-...

# (Prod uniquement — Render injecte PORT automatiquement, pas besoin de le changer)
